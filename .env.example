# ============================================================
# Ubuy QA Automation — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env with real credentials.
# ============================================================

# Base URL for the target storefront
BASE_URL=https://www.ubuy.co.in

# Test account credentials (use a dedicated test account, not a personal one)
TEST_USER_EMAIL=your-test-account@example.com
TEST_USER_PASSWORD=your-test-password

# Optional: registration test email prefix (timestamp will be appended)
TEST_REGISTER_EMAIL_PREFIX=ubuy.qa.test

# Optional: CI-specific overrides
# CI=true
# HEADLESS=true
