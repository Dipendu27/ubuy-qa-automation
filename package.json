{
  "name": "ubuy-qa-automation",
  "version": "1.0.0",
  "description": "Production-grade E2E UI test automation framework for ubuy.co.in — Playwright + TypeScript, Page Object Model",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:p0": "npx playwright test tests/p0-critical-path/",
    "test:p1": "npx playwright test tests/p1-business-rules/",
    "test:p2": "npx playwright test tests/p2-content-seo/",
    "test:chromium": "npx playwright test --project=chromium-desktop",
    "test:mobile": "npx playwright test --project=mobile-chrome",
    "report": "npx playwright show-report reports/html",
    "lint": "eslint src/ tests/ --ext .ts",
    "lint:fix": "eslint src/ tests/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "dotenv": "^16.5.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-playwright": "^2.2.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
