{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:playwright/recommended",
    "prettier"
  ],
  "rules": {
    "@typescript-eslint/no-explicit-any": "warn",
    "@typescript-eslint/no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "playwright/no-skipped-test": "off",
    "playwright/expect-expect": [
      "warn",
      {
        "assertFunctionNames": [
          "expect",
          "expectFormRendered",
          "expectErrorMessage",
          "expectCartHasItems",
          "expectCartEmpty",
          "expectStepRendered",
          "expectShippingOptionsVisible",
          "expectOrderSummaryVisible",
          "expectCoreElementsVisible",
          "expectHeaderRendered",
          "expectFooterVisible",
          "expectBreadcrumbVisible",
          "expectEmptyState",
          "expectDashboardRendered",
          "expectOrderHistoryVisible",
          "expectConfirmModalVisible",
          "expectSwitcherVisible",
          "expectInStock",
          "expectOutOfStock",
          "expectPageRendered",
          "expectResultsDisplayed",
          "expectProductsDisplayed",
          "expectPaymentMethodsVisible",
          "expectDeliverabilityError",
          "expectNoDeliverabilityError",
          "expectValidationErrors",
          "expectErrorMessageContains",
          "expectSocialLoginVisible",
          "expectTrackingResultVisible",
          "expectTrackingError",
          "expectAddToCartDisabled",
          "expectAddToCartSuccessMessage",
          "expectRegistrationSuccess",
          "expectRegistrationError"
        ]
      }
    ],
    "playwright/no-conditional-in-test": "off",
    "playwright/no-nested-step": "off"
  },
  "env": {
    "node": true,
    "es6": true
  }
}
